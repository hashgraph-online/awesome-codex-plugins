{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/registry/scripts/install.js"
          }
        ],
        "description": "Install transpile binary if missing (cross-platform)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "TP=$(command -v transpile 2>/dev/null); if [ -n \"$TP\" ]; then \"$TP\" --input \"$TP_INPUT\" --fidelity semantic --quiet; else echo '[transpile] binary not found, skipping'; fi"
          }
        ],
        "description": "Auto-compress .md, .html, .txt files after Read"
      }
    ]
  }
}
