#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd -P)
PLUGIN_DIR=$(CDPATH= cd "$SCRIPT_DIR/.." && pwd -P)

node_is_compatible() {
  "$1" -e 'const major = Number(process.versions.node.split(".")[0]); process.exit(major >= 20 ? 0 : 1);' >/dev/null 2>&1
}

find_node() {
  if [ "${NODE:-}" ] && [ -x "${NODE:-}" ] && node_is_compatible "$NODE"; then
    printf '%s\n' "$NODE"
    return 0
  fi

  if command -v node >/dev/null 2>&1; then
    candidate=$(command -v node)
    if node_is_compatible "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  for candidate in \
    /opt/homebrew/bin/node \
    /usr/local/bin/node \
    /usr/bin/node \
    "$HOME/.nvm/current/bin/node" \
    "$HOME/.volta/bin/node" \
    "$HOME/.asdf/shims/node"; do
    if [ -x "$candidate" ] && node_is_compatible "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if [ -x /bin/zsh ]; then
    candidate=$(/bin/zsh -lc 'command -v node' 2>/dev/null || true)
    if [ "$candidate" ] && [ -x "$candidate" ] && node_is_compatible "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  return 1
}

NODE_BIN=$(find_node) || {
  printf '%s\n' "Coolify MCP server could not find Node.js 20 or newer. Install Node.js or set NODE to the node binary path." >&2
  exit 127
}

exec "$NODE_BIN" "$PLUGIN_DIR/src/server.js"
