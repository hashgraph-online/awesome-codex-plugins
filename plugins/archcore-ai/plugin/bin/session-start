#!/bin/sh
# SessionStart hook: load archcore context via the CLI on PATH.
# Uses normalized stdin — works across Claude Code, Cursor, and other hosts.

SCRIPT_DIR=$(dirname "$0")
# shellcheck source=lib/normalize-stdin.sh
. "$SCRIPT_DIR/lib/normalize-stdin.sh"

# Check if archcore CLI is available on PATH
if ! command -v archcore >/dev/null 2>&1; then
  _msg="[Archcore] CLI not found on PATH. Install it first:
  macOS/Linux/WSL: curl -fsSL https://archcore.ai/install.sh | bash
  Windows (PowerShell): irm https://archcore.ai/install.ps1 | iex
  Then verify: archcore --version
  Docs: https://docs.archcore.ai/cli/install/"
  case "$ARCHCORE_HOST" in
    claude-code|copilot)
      _escaped=$(printf '%s' "$_msg" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk 'BEGIN{ORS="\\n"}{print}')
      printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}' "$_escaped"
      ;;
    *)
      printf '%s\n' "$_msg"
      ;;
  esac
  exit 0
fi

# Refuse to run when cwd looks like a plugin install directory. Hosts can
# misroute cwd (notably Cursor stdio hooks — see forum #99215) and launch us
# inside ~/.cursor/plugins/cache/.../<sha>/ instead of the user workspace.
# Without this guard, session-start would read the plugin's own bundled
# .archcore/ and surface it as "the user's knowledge base."
if [ -f ".cursor-plugin/plugin.json" ] \
  || [ -f ".claude-plugin/plugin.json" ] \
  || [ -f ".codex-plugin/plugin.json" ]; then
  # Silent exit — host shouldn't see noise during normal session-start.
  exit 0
fi

# Emit informational context to the agent (structured for Claude Code/Copilot, plain for others).
_archcore_emit_info() {
  _msg="$1"
  case "$ARCHCORE_HOST" in
    claude-code|copilot)
      _escaped=$(printf '%s' "$_msg" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk 'BEGIN{ORS="\\n"}{print}')
      printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}' "$_escaped"
      ;;
    *)
      printf '%s\n' "$_msg"
      ;;
  esac
}

# shellcheck source=lib/empty-state.sh
. "$SCRIPT_DIR/lib/empty-state.sh"

# Check if .archcore/ exists. If not, the plugin's MCP server starts in
# uninitialized mode — the agent can call mcp__archcore__init_project to
# initialize on demand. No manual setup required.
if [ ! -d ".archcore" ]; then
  _init_msg="[Archcore] no .archcore/ directory in this project yet. When the user asks for any Archcore operation (create ADR, audit docs, etc.), call mcp__archcore__init_project once to initialize, then proceed. Do NOT write to .archcore/ directly — hooks will block it."
  if [ "${ARCHCORE_HIDE_EMPTY_NUDGE:-}" != "1" ]; then
    _init_msg="${_init_msg} After init, suggest the user run /archcore:init to seed initial content (stack rule, run-the-app guide, optional import of existing CLAUDE.md / AGENTS.md / .cursorrules). Skip with ARCHCORE_HIDE_EMPTY_NUDGE=1."
  fi
  _archcore_emit_info "$_init_msg"
  exit 0
fi

# Initialized project — run the host-specific session-start hook via CLI.
printf '%s' "$ARCHCORE_RAW_STDIN" | archcore hooks "$ARCHCORE_HOST" session-start 2>/dev/null || true

# Empty-state nudge: .archcore/ exists but carries no substantive documents.
# Emitted as plain text (follows the staleness-output pattern below) so it
# never competes with the CLI hook's structured output for the same JSON slot.
if [ "${ARCHCORE_HIDE_EMPTY_NUDGE:-}" != "1" ] && archcore_is_functionally_empty ".archcore"; then
  echo ""
  echo "[Archcore] .archcore/ is empty. Run /archcore:init to seed a stack rule, a run-the-app guide, and (optionally) imports from existing agent-instruction files like CLAUDE.md or AGENTS.md. Skip with ARCHCORE_HIDE_EMPTY_NUDGE=1."
fi

# Run staleness check (code-document drift detection)
STALENESS=$("$SCRIPT_DIR/check-staleness" 2>/dev/null) || true
if [ -n "$STALENESS" ]; then
  echo ""
  echo "$STALENESS"
fi
