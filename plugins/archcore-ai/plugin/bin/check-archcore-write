#!/bin/sh
# PreToolUse hook: block direct Write/Edit to .archcore/ document files.
# Uses normalized stdin — works across Claude Code, Cursor, and other hosts.
# Blocks via archcore_hook_block (exit 2 for CC, JSON for Cursor).
# Allows via archcore_hook_allow (exit 0).

SCRIPT_DIR=$(dirname "$0")
# shellcheck source=lib/normalize-stdin.sh
. "$SCRIPT_DIR/lib/normalize-stdin.sh"

# If no file_path found, allow
if [ -z "$ARCHCORE_FILE_PATH" ]; then
  archcore_hook_allow
fi

# Normalize: check if path contains .archcore/ and ends with .md
case "$ARCHCORE_FILE_PATH" in
  *.archcore/settings.json|*.archcore/.sync-state.json)
    # Allow config and manifest files
    archcore_hook_allow
    ;;
  *.archcore/*.md)
    # Block direct writes to .archcore/ markdown documents
    archcore_hook_block "Direct writes to .archcore/ documents are not allowed. Use Archcore MCP tools instead:
- create_document: create a new document
- update_document: modify an existing document
- remove_document: delete a document
This ensures validation, templates, and the sync manifest stay consistent."
    ;;
  *)
    # Allow everything else
    archcore_hook_allow
    ;;
esac
