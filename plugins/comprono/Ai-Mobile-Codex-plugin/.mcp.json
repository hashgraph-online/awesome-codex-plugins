{
  "mcpServers": {
    "ai-mobile-devtools": {
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"$env:USERPROFILE\\plugins\\ai-mobile\\scripts\\ai-mobile-devtools-mcp.ps1\""
      ],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      }
    },
    "ai-mobile-local": {
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& node \"$env:USERPROFILE\\plugins\\ai-mobile\\scripts\\ai-mobile-local-mcp.js\""
      ]
    }
  }
}
